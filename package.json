{
  "name": "cursor-zh-hans-language-pack",
  "displayName": "Cursor 简体中文全局汉化包",
  "description": "为 Cursor 提供全局简体中文界面语言包，并附带可逆的 Cursor 扩展清单和 Agent/Composer 主界面汉化补丁。",
  "version": "0.1.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YeYu-Wang/cursor-zh-hans-language-pack.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Language Packs",
    "Other"
  ],
  "keywords": [
    "Cursor",
    "中文",
    "简体中文",
    "汉化",
    "语言包",
    "localization",
    "zh-cn"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cursorZhHans.applyManifestPatch",
    "onCommand:cursorZhHans.revertManifestPatch",
    "onCommand:cursorZhHans.applyWorkbenchPatch",
    "onCommand:cursorZhHans.revertWorkbenchPatch",
    "onCommand:cursorZhHans.inspectWorkbenchPatch",
    "onCommand:cursorZhHans.configureDisplayLanguage",
    "onCommand:cursorZhHans.openGuide"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cursorZhHans.applyManifestPatch",
        "title": "应用 Cursor 扩展清单汉化补丁",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.revertManifestPatch",
        "title": "恢复 Cursor 扩展清单原文",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.applyWorkbenchPatch",
        "title": "应用 Cursor Agent/Composer 主界面汉化补丁",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.revertWorkbenchPatch",
        "title": "恢复 Cursor Agent/Composer 主界面原文",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.inspectWorkbenchPatch",
        "title": "检查 Cursor Agent/Composer 主界面汉化补丁",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.configureDisplayLanguage",
        "title": "打开显示语言设置",
        "category": "Cursor 简体中文"
      },
      {
        "command": "cursorZhHans.openGuide",
        "title": "打开 Cursor 简体中文使用说明",
        "category": "Cursor 简体中文"
      }
    ],
    "configuration": {
      "title": "Cursor 简体中文汉化",
      "properties": {
        "cursorZhHans.extensionsRoot": {
          "type": "string",
          "default": "",
          "description": "Cursor 扩展目录。留空时使用当前用户目录下的 .cursor/extensions。"
        },
        "cursorZhHans.cursorAppRoot": {
          "type": "string",
          "default": "",
          "description": "Cursor 应用资源目录。留空时自动定位当前 Cursor 的 resources/app 目录。"
        },
        "cursorZhHans.autoApplyWorkbenchPatch": {
          "type": "boolean",
          "default": true,
          "description": "启动 Cursor 时自动检查并补回主程序硬编码汉化补丁，降低升级覆盖后的回退概率。"
        }
      }
    },
    "localizations": [
